# Turso / libSQL (preferred)
TURSO_DATABASE_URL="libsql://your-database-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Optional compatibility alias (used only if TURSO_DATABASE_URL is not set)
# DATABASE_URL="libsql://your-database-name-your-org.turso.io"

# Analytics (uncomment one)
# NEXT_PUBLIC_GA4_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="showmehv.com"

# Google Ads (public tag; default is baked into code). Set the conversion
# label from the Google Ads conversion action's event snippet (the part after
# "AW-XXXX/") to fire the lead conversion on the get-offer thank-you page.
# NEXT_PUBLIC_GOOGLE_ADS_ID="AW-18305817967"
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL="xxxxxxxxxxxxxxxxxxx"

# Webhook integration (optional - set URL to enable)
# WEBHOOK_URL="https://hooks.zapier.com/hooks/catch/xxx/yyy"
# WEBHOOK_SECRET="your-webhook-secret"

# Site
NEXT_PUBLIC_SITE_URL="https://showmehv.com"
NEXT_PUBLIC_PHONE="417-258-5577"
NEXT_PUBLIC_EMAIL="jordanrhodes@kw.com"
